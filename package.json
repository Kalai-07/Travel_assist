{
  "name": "travel-assist",
  "version": "1.0.0",
  "description": "AI-Driven IoT Framework for Integrated Roadside Assistance and Intelligent Mobility Services",
  "private": true,
  "scripts": {
    "dev":           "vite",
    "build":         "vite build",
